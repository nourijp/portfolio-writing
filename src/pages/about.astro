---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Hamed Nouri Writing Archive">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4">About</h1>
      <p class="text-xl text-muted-foreground">
        Hamed Nouri — Writing Archive
      </p>
    </header>
    
    <div class="prose prose-lg dark:prose-invert max-w-none" transition:animate="fade">
      <p>
        This archive collects selected writing samples by Hamed Nouri, including communications writing, 
        technical and instructional content, essays, educational writing, creative work, scripts, 
        and bilingual/Japanese-related pieces.
      </p>
      
      <p>
        I write across communications, documentation, education, creative media, and cross-cultural topics. 
        This archive is a place to collect selected samples that show range: clear explanations, structured 
        guides, essays, scripts, learning materials, creative work, and bilingual writing.
      </p>
      
      <h2>Writing Categories</h2>
      
      <ul>
        <li><strong>Communications Writing</strong> — Internal communications, announcements, stakeholder messaging, launch communications, newsletters, and audience-specific updates.</li>
        <li><strong>Technical Writing</strong> — Guides, documentation, FAQs, how-to articles, process notes, release notes, onboarding materials, and instructional content.</li>
        <li><strong>Essays</strong> — Reflective essays, opinion writing, personal essays, culture, media, learning, technology, and faith-related writing.</li>
        <li><strong>Educational Writing</strong> — Lesson materials, learning content, curriculum-style writing, explanations, study guides, and family/child-focused educational content.</li>
        <li><strong>Creative Writing</strong> — Story concepts, fiction excerpts, comics/manga writing, character-based writing, children's content, and creative development notes.</li>
        <li><strong>Scripts &amp; Media</strong> — Podcast scripts, video scripts, documentary notes, narration, interview prompts, and multimedia writing.</li>
        <li><strong>Japanese / Bilingual Writing</strong> — Japanese-related writing, bilingual communication, localization samples, Japanese study materials, cultural explanation, and cross-cultural content.</li>
      </ul>

      <h2>Contact</h2>
      <p>
        For writing, editing, documentation, or content-related opportunities, contact 
        <a href="mailto:writing@hamednouri.com">writing@hamednouri.com</a>.
      </p>
    </div>
  </div>
</BaseLayout>
